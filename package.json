{
  "name": "dhandapani-grocery-shop",
  "version": "1.0.0",
  "description": "தண்டபாணி மளிகை கடை - Grocery Debt Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win portable",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.dhandapani.grocery",
    "productName": "Dhandapani Grocery Shop",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
